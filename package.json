{
  "name": "multilingual-translator",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate && react-router build",
    "dev": "shopify app dev",
    "dev:local": "shopify app dev --use-localhost --config shopify.app.local.toml",
    "start": "react-router-serve ./build/server/index.js",
    "postinstall": "prisma generate",
    "setup": "prisma generate && prisma db push",
    "docker-start": "npm run setup && npm run start",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "@react-router/dev": "^7.12.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "@vercel/functions": "^3.6.1",
    "@vercel/react-router": "^1.3.1",
    "isbot": "^5.1.31",
    "prisma": "^6.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@shopify/polaris-types": "1.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "typescript": "^5.9.3",
    "vite": "^6.3.6"
  }
}
